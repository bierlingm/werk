{
  "productName": "werk",
  "version": "0.1.0",
  "identifier": "com.werk.app",
  "build": {
    "frontendDist": "../src-web"
  },
  "app": {
    "windows": [
      {
        "title": "werk",
        "width": 960,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"],
    "targets": "all"
  }
}
